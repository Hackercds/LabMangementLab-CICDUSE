{
  "info": {
    "name": "实验室管理系统API",
    "description": "实验室管理系统的RESTful API接口文档",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "认证管理",
      "item": [
        {
          "name": "用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 解析响应",
                  "var jsonData = pm.response.json();",
                  "",
                  "// 检查响应状态",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 检查响应数据",
                  "pm.test('Response has token', function () {",
                  "    pm.expect(jsonData.data).to.have.property('token');",
                  "});",
                  "",
                  "// 自动设置token到环境变量",
                  "if (jsonData.code === 200 && jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "    console.log('Token已自动设置:', jsonData.data.token.substring(0, 20) + '...');",
                  "}",
                  "",
                  "// 显示用户信息",
                  "if (jsonData.data) {",
                  "    console.log('登录用户:', jsonData.data.realName);",
                  "    console.log('用户角色:', jsonData.data.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student\",\n  \"password\": \"123456\",\n  \"realName\": \"测试学生\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "修改密码",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"admin123\",\n  \"newPassword\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password",
              "host": ["{{base_url}}"],
              "path": ["auth", "password"]
            }
          }
        }
      ]
    },
    {
      "name": "预约管理",
      "item": [
        {
          "name": "查询已占用时间段",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reservation/busy?labId=1&date=2026-04-15",
              "host": ["{{base_url}}"],
              "path": ["reservation", "busy"],
              "query": [
                {
                  "key": "labId",
                  "value": "1"
                },
                {
                  "key": "date",
                  "value": "2026-04-15"
                }
              ]
            }
          }
        },
        {
          "name": "获取我的预约列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reservation/my?current=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["reservation", "my"],
              "query": [
                {
                  "key": "current",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "管理端分页查询预约",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reservation/list?current=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["reservation", "list"],
              "query": [
                {
                  "key": "current",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "labId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "userId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "date",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "获取预约详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reservation/1",
              "host": ["{{base_url}}"],
              "path": ["reservation", "1"]
            }
          }
        },
        {
          "name": "提交预约申请",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"labId\": 1,\n  \"reservationDate\": \"2026-04-15\",\n  \"startTime\": \"09:00\",\n  \"endTime\": \"11:00\",\n  \"purpose\": \"测试预约\",\n  \"participantCount\": 10\n}"
            },
            "url": {
              "raw": "{{base_url}}/reservation",
              "host": ["{{base_url}}"],
              "path": ["reservation"]
            }
          }
        },
        {
          "name": "用户取消预约",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/reservation/1/cancel",
              "host": ["{{base_url}}"],
              "path": ["reservation", "1", "cancel"]
            }
          }
        },
        {
          "name": "审批预约",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 检查响应状态",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 显示审批结果",
                  "var jsonData = pm.response.json();",
                  "console.log('审批结果:', jsonData);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/reservation/1/approve?status=APPROVED&comment=审批通过",
              "host": ["{{base_url}}"],
              "path": ["reservation", "1", "approve"],
              "query": [
                {
                  "key": "status",
                  "value": "APPROVED"
                },
                {
                  "key": "comment",
                  "value": "审批通过"
                }
              ]
            }
          }
        }
      ]
    },
