        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="从文件一次性加载所有token到内存" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import java.nio.file.*;
import java.nio.charset.StandardCharsets;

if (props.get(&quot;tokenListLoaded&quot;) == &quot;true&quot;) return;

String baseDir = org.apache.jmeter.services.FileServer.getFileServer().getBaseDir();
String filePath = baseDir + java.io.File.separator + &quot;user-tokens.csv&quot;;
int retries = 0;
java.util.List lines = null;
while (retries &lt; 60) {
    try {
        lines = Files.readAllLines(Paths.get(filePath), StandardCharsets.UTF_8);
        int count = lines.size() - 1;
        if (count &gt;= 100) {
            break;
        }
    } catch (Exception e) {
        // ignore
    }
    Thread.sleep(1000);
    retries++;
}
if (lines == null || lines.size() &lt; 2) {
    log.error(&quot;[B组] 无法读取user-tokens.csv!&quot;);
    return;
}
synchronized (props) {
     if (props.get(&quot;tokenListLoaded&quot;) == &quot;true&quot;) return;
     int idx = 0;
     for (int i = 1; i &lt; lines.size(); i++) {
         String line = ((String) lines.get(i)).trim();
         if (line.length() &gt; 0) {
             String[] parts = line.split(&quot;,&quot;, 2);
             props.put(&quot;token_idx_&quot; + idx, parts[1]);
             idx++;
         }
     }
     props.put(&quot;tokenCount&quot;, idx);
     props.put(&quot;tokenListLoaded&quot;, &quot;true&quot;);
 }
log.info(&quot;[B组] 已加载 &quot; + (lines.size() - 1) + &quot; 个token到内存&quot;);</stringProp>
          <stringProp name="language">groovy</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
