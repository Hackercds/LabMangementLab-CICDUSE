          <stringProp name="script">int threadNum = ctx.getThreadNum();
String token = props.get(&quot;token_idx_&quot; + threadNum);
if (token != null) {
    vars.put(&quot;myToken&quot;, token);
} else {
    log.warn(&quot;[B组] 线程#&quot; + threadNum + &quot; 未找到token&quot;);
}</stringProp>
