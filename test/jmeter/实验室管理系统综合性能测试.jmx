            <hashTree/>
            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="写入token到CSV" enabled="true">
              <stringProp name="BeanShellPostProcessor.reset_interpreter">false</stringProp>
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">String token = vars.get(&quot;loginToken&quot;);
String user = vars.get(&quot;csv_user&quot;);
if (token != null &amp;&amp; !token.equals(&quot;NOT_FOUND&quot;)) {
    synchronized (this) {
        String baseDir = org.apache.jmeter.services.FileServer.getFileServer().getBaseDir();
        String filePath = baseDir + java.io.File.separator + &quot;user-tokens.csv&quot;;
        String line = user + &quot;,&quot; + token + &quot;\n&quot;;
        try {
            java.io.FileOutputStream fos = new java.io.FileOutputStream(filePath, true);
            fos.write(line.getBytes(&quot;UTF-8&quot;));
            fos.close();
            log.info(&quot;已写入token: &quot; + user);
        } catch (Exception e) {
            log.error(&quot;写入token失败: &quot; + e.getMessage());
        }
    }
}</stringProp>
            </BeanShellPostProcessor>
