        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="按行号读取test-users.csv">
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.nio.file.*;
import java.nio.charset.StandardCharsets;

String baseDir = org.apache.jmeter.services.FileServer.getFileServer().getBaseDir();
String csvPath = baseDir + java.io.File.separator + &quot;test-users.csv&quot;;

synchronized (props) {
    Integer counter = (Integer) props.get(&quot;preLoginCounter&quot;);
    if (counter == null) {
        counter = 0;
        props.put(&quot;preLoginCounter&quot;, counter);
    } else {
        counter++;
        props.put(&quot;preLoginCounter&quot;, counter);
    }
    
    List&lt;String&gt; lines = Files.readAllLines(Paths.get(csvPath), StandardCharsets.UTF_8);
    int targetLine = counter + 1;
    if (targetLine &lt; lines.size()) {
        String[] parts = lines.get(targetLine).split(&quot;,&quot;);
        vars.put(&quot;csv_user&quot;, parts[0]);
        vars.put(&quot;csv_pass&quot;, parts[1]);
        vars.put(&quot;csv_name&quot;, parts[2]);
        vars.put(&quot;csv_role&quot;, parts[3]);
        log.info(&quot;[预登录] 读取第&quot; + targetLine + &quot;行: &quot; + parts[0]);
    } else {
        log.error(&quot;[预登录] 行号超出: &quot; + targetLine + &quot;, 总行数: &quot; + lines.size());
    }
}</stringProp>
            <stringProp name="language">groovy</stringProp>
