# ============================================
# 实验室管理系统 - 环境配置模板
# 复制此文件为 .env 并修改实际值
#   cp .env.example .env
# 警告: .env 包含敏感信息，不要提交到 Git！
# ============================================

# 部署主机IP（本地开发用 localhost，生产填实际IP）
HOST_IP=localhost

# 后端服务端口
BACKEND_PORT=8081

# 前端服务端口
FRONTEND_PORT=80

# MySQL配置（生产环境请务必修改密码！）
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=lab_management
MYSQL_USER=labuser
MYSQL_PASSWORD=change-me-user-password

# Redis配置
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置（生产环境请生成随机密钥）
JWT_SECRET=change-me-generate-random-secret
JWT_EXPIRATION=86400000

# CORS配置（生产环境请填写前端实际域名）
CORS_ALLOWED_ORIGINS=http://localhost

# JVM参数
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# 监控系统（生产环境建议开启）
MONITOR_ENABLED=false
