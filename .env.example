# ============================================
# 实验室管理系统 - 唯一配置文件模板
# 使用方法: cp .env.example .env  然后修改 .env
# 所有部署方式共用此文件（Docker Compose、Jenkins、裸机）
# 遵循 MICRO_SERVICE_SPEC.md 第 2.1 节
# ============================================

# ---------- 部署主机 ----------
HOST_IP=localhost

# ---------- 服务端口 ----------
BACKEND_PORT=8081
FRONTEND_PORT=80

# ---------- MySQL ----------
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=lab_management
MYSQL_USER=labuser
MYSQL_PASSWORD=change-me

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
JWT_SECRET=change-me-to-random-string
JWT_EXPIRATION=86400000

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=*

# ---------- JVM ----------
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# ---------- Spring ----------
SPRING_PROFILES_ACTIVE=prod

# ---------- 监控 ----------
MONITOR_ENABLED=false
