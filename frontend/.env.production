# 生产环境配置
VITE_APP_TITLE=实验室管理系统
VITE_APP_ENV=production

# API配置
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=20000

# 上传配置
VITE_UPLOAD_MAX_SIZE=20971520
VITE_UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# 功能开关
VITE_ENABLE_MOCK=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_CONSOLE_LOG=false

# 其他配置
VITE_TOKEN_KEY=lab_token
VITE_TOKEN_PREFIX=Bearer 
VITE_DEFAULT_LANGUAGE=zh-CN
