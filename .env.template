# ==================== 环境变量配置文件模板 ====================
# 复制此文件为 .env 并填写实际值

# ==================== 应用配置 ====================
SPRING_APPLICATION_NAME=lab-management
SPRING_PROFILES_ACTIVE=dev
APP_NAME=实验室管理系统
APP_VERSION=1.0.0
APP_DESCRIPTION=实验室管理系统API

# ==================== 服务器配置 ====================
SERVER_PORT=8081
SERVER_CONTEXT_PATH=/api
SERVER_MAX_THREADS=200
SERVER_MIN_THREADS=10
SERVER_ACCEPT_COUNT=100
SERVER_MAX_CONNECTIONS=10000
SERVER_CONNECTION_TIMEOUT=5000

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lab_management
DB_USERNAME=labuser
DB_PASSWORD=your_password_here

# 数据库连接池配置
DB_POOL_MIN_IDLE=5
DB_POOL_MAX_SIZE=20
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000
DB_POOL_CONNECTION_TIMEOUT=30000

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0
REDIS_TIMEOUT=5000

# Redis连接池配置
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=-1

# ==================== JWT配置 ====================
JWT_SECRET=your_jwt_secret_key_here_please_change_in_production
JWT_EXPIRATION=86400000
JWT_HEADER=Authorization
JWT_PREFIX=Bearer 
JWT_ISSUER=lab-management

# ==================== 日志配置 ====================
LOG_LEVEL_ROOT=info
LOG_LEVEL_APP=debug
LOG_LEVEL_SPRING=info
LOG_LEVEL_MYBATIS=info
LOG_LEVEL_HIKARI=info
LOG_FILE_NAME=logs/lab-management.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30
LOG_FILE_TOTAL_SIZE_CAP=1GB

# ==================== MyBatis配置 ====================
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.stdout.StdOutImpl
MYBATIS_STATEMENT_TIMEOUT=30
MYBATIS_TABLE_PREFIX=

# ==================== Actuator监控配置 ====================
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
ACTUATOR_BASE_PATH=/actuator
ACTUATOR_HEALTH_SHOW_DETAILS=when-authorized
ACTUATOR_HEALTH_DISK_THRESHOLD=10MB
ACTUATOR_PROMETHEUS_ENABLED=true

# ==================== 跨域配置 ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ==================== 安全配置 ====================
SECURITY_IGNORE_URLS=/auth/login,/auth/register,/actuator/**
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ==================== 文件上传配置 ====================
UPLOAD_MAX_FILE_SIZE=10MB
UPLOAD_MAX_REQUEST_SIZE=10MB
UPLOAD_FILE_SIZE_THRESHOLD=2KB

# ==================== 文件存储配置 ====================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_SIZE=10MB
STORAGE_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ==================== 异步任务配置 ====================
ASYNC_POOL_CORE_SIZE=5
ASYNC_POOL_MAX_SIZE=20
ASYNC_POOL_QUEUE_CAPACITY=100
ASYNC_POOL_KEEP_ALIVE=60

# ==================== 定时任务配置 ====================
SCHEDULING_POOL_SIZE=5

# ==================== 缓存配置 ====================
CACHE_TYPE=redis
CACHE_TTL=3600000

# ==================== 业务配置 ====================
# 预约配置
RESERVATION_MAX_DAYS=30
RESERVATION_MIN_HOURS=2
RESERVATION_MAX_HOURS=8
RESERVATION_CANCEL_HOURS=24

# 设备配置
DEVICE_MAX_BORROW_DAYS=30
DEVICE_OVERDUE_FINE=10.0

# 耗材配置
CONSUMABLE_WARNING_THRESHOLD=10
CONSUMABLE_AUTO_WARNING=true

# ==================== 通知配置 ====================
# 邮件通知
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_HOST=smtp.example.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USERNAME=your_email@example.com
NOTIFICATION_EMAIL_PASSWORD=your_email_password
NOTIFICATION_EMAIL_FROM=noreply@example.com

# 短信通知
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_SMS_PROVIDER=aliyun
NOTIFICATION_SMS_ACCESS_KEY=your_access_key
NOTIFICATION_SMS_SECRET_KEY=your_secret_key

# ==================== Docker Registry配置 ====================
DOCKER_REGISTRY=registry.example.com
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# ==================== 部署服务器配置 ====================
DEPLOY_SERVER=your.server.ip
DEPLOY_USER=deploy
SSH_PRIVATE_KEY=your_ssh_private_key_here

# ==================== 监控配置 ====================
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d
